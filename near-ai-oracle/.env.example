# NEAR AI Oracle - Environment Configuration
# Copy this file to .env and fill in your values

# Your OpenRouter API key (get it from https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model to use (see https://openrouter.ai/models for options)
# Popular choices:
#   meta-llama/llama-4-maverick   (free/cheap)
#   google/gemini-2.5-flash       (fast & cheap)  
#   openai/gpt-4o-mini            (good balance)
#   anthropic/claude-sonnet-4     (high quality)
OPENROUTER_MODEL=meta-llama/llama-4-maverick

# NEAR contract & account settings
CONTRACT_ID=ai-oracle-123.testnet
ORACLE_ACCOUNT=ai-oracle-123.testnet

# NEAR RPC endpoint
NEAR_RPC=https://rpc.testnet.near.org

# How often to check for new requests (in seconds)
POLL_INTERVAL=5
